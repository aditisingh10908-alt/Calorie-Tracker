# ============================================
# Calorie Deficit & Weight Loss Tracker
# Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# --- PostgreSQL Database ---
POSTGRES_USER=calorie_user
POSTGRES_PASSWORD=calorie_pass_2024
POSTGRES_DB=calorie_tracker

# --- Backend Service ---
DATABASE_URL=postgresql://calorie_user:calorie_pass_2024@localhost:5432/calorie_tracker?schema=public
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_change_this_in_production
JWT_EXPIRES_IN=7d
ML_SERVICE_URL=http://localhost:8000
BACKEND_PORT=5000
NODE_ENV=development

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# --- ML Service ---
ML_PORT=8000
BACKEND_URL=http://localhost:5000
MODEL_DIR=./saved_models

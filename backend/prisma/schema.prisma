generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
}

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  password      String
  age           Int?
  gender        String?
  height        Float?
  currentWeight Float?
  goalWeight    Float?
  activityLevel String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  foods         Food[]
  favoriteFoods FavoriteFood[]
  meals         Meal[]
  weightLogs    WeightLog[]
  waterLogs     WaterLog[]
  proteinLogs   ProteinLog[]
  calorieLogs   CalorieLog[]
  goals         Goal[]
  streaks       Streak[]
  notifications Notification[]

  @@map("users")
}

model Food {
  id          String    @id @default(uuid())
  name        String
  servingSize Float
  servingUnit String
  calories    Float
  protein     Float
  carbs       Float
  fats        Float
  category    String?
  isDefault   Boolean   @default(true)
  createdBy   User?     @relation(fields: [createdById], references: [id])
  createdById String?
  deletedAt   DateTime?

  mealItems     MealItem[]
  favoriteFoods FavoriteFood[]

  @@map("foods")
}

model FavoriteFood {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  food      Food     @relation(fields: [foodId], references: [id])
  foodId    String
  createdAt DateTime @default(now())

  @@unique([userId, foodId])
  @@map("favorite_foods")
}

model Meal {
  id        String    @id @default(uuid())
  user      User      @relation(fields: [userId], references: [id])
  userId    String
  date      DateTime
  mealType  MealType
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  items MealItem[]

  @@map("meals")
}

model MealItem {
  id       String @id @default(uuid())
  meal     Meal   @relation(fields: [mealId], references: [id], onDelete: Cascade)
  mealId   String
  food     Food   @relation(fields: [foodId], references: [id])
  foodId   String
  quantity Float  @default(1)
  calories Float
  protein  Float
  carbs    Float
  fats     Float

  @@map("meal_items")
}

model WeightLog {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  weight    Float
  date      DateTime
  note      String?
  createdAt DateTime @default(now())

  @@map("weight_logs")
}

model WaterLog {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  amount    Int
  date      DateTime
  time      String?
  createdAt DateTime @default(now())

  @@map("water_logs")
}

model ProteinLog {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  amount    Float
  date      DateTime
  source    String?
  createdAt DateTime @default(now())

  @@map("protein_logs")
}

model CalorieLog {
  id             String   @id @default(uuid())
  user           User     @relation(fields: [userId], references: [id])
  userId         String
  totalCalories  Float
  targetCalories Float
  deficit        Float
  date           DateTime
  createdAt      DateTime @default(now())

  @@map("calorie_logs")
}

model Goal {
  id           String    @id @default(uuid())
  user         User      @relation(fields: [userId], references: [id])
  userId       String
  goalType     String
  targetValue  Float
  currentValue Float
  startDate    DateTime
  targetDate   DateTime?
  status       String    @default("ACTIVE")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("goals")
}

model Streak {
  id            String    @id @default(uuid())
  user          User      @relation(fields: [userId], references: [id])
  userId        String
  streakType    String
  currentStreak Int       @default(0)
  longestStreak Int       @default(0)
  lastLogDate   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("streaks")
}

model Notification {
  id          String    @id @default(uuid())
  user        User      @relation(fields: [userId], references: [id])
  userId      String
  type        String
  message     String
  isRead      Boolean   @default(false)
  scheduledAt DateTime?
  createdAt   DateTime  @default(now())

  @@map("notifications")
}
